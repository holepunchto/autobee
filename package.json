{
  "name": "autobee",
  "version": "0.0.0",
  "description": "A multi-writer KV-store built with Autobase and Hyperbee",
  "main": "index.js",
  "scripts": {
    "build": "protocol-buffers -o lib/messages.js lib/schema.proto",
    "test": "standard && tape test/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewosh/autobee.git"
  },
  "keywords": [
    "autobase",
    "hyperbee"
  ],
  "author": "Andrew Osheroff <andrewosh@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/andrewosh/autobee/issues"
  },
  "homepage": "https://github.com/andrewosh/autobee#readme",
  "devDependencies": {
    "protocol-buffers": "^4.2.0",
    "random-access-memory": "^3.1.2",
    "standard": "^16.0.3",
    "tape": "^5.1.1",
    "corestore": "github:andrewosh/neocorestore#omega",
    "immutable-store": "./immutable-store"
  },
  "dependencies": {
    "autobase": "github:mafintosh/autobase",
    "codecs": "^2.2.0",
    "hyperbee": "^1.5.3",
    "hypercore-crypto": "^2.2.0",
    "omega": "github:mafintosh/omega",
    "protocol-buffers-encodings": "^1.1.1"
  },
  "standard": {
    "ignore": [
      "lib/messages.js"
    ]
  }
}
