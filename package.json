{
  "name": "autobee",
  "version": "1.0.10",
  "description": "Bee based autobase",
  "license": "Apache-2.0",
  "author": "Holepunch Inc.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/autobee.git"
  },
  "files": [
    "index.js",
    "lib/*.js",
    "encoding"
  ],
  "scripts": {
    "format": "prettier . --write",
    "lint": "lunte && prettier . --check",
    "test": "node test/all.js",
    "test:bare": "bare test/all.js",
    "test:encrypted": "bare test/all.js --encrypt-all",
    "test:generate": "brittle -r test/all.js test/*.js"
  },
  "dependencies": {
    "autobee-encryption": "^0.1.2",
    "autobee-wakeup": "^1.1.3",
    "b4a": "^1.8.0",
    "compact-encoding": "^2.18.0",
    "hyperbee2": "^2.10.3",
    "hypercore": "^11.33.2",
    "hypercore-id-encoding": "^1.3.0",
    "hyperschema": "^1.20.1",
    "ready-guard": "^1.0.0",
    "ready-resource": "^1.2.0",
    "resolve-reject-promise": "^1.1.0",
    "safety-catch": "^1.0.3"
  },
  "devDependencies": {
    "brittle": "^4.1.0",
    "corestore": "^7.11.0",
    "hypercore-crypto": "^3.6.1",
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "protomux-wakeup": "^2.9.0"
  }
}
